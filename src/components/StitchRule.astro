---
// Regla decorativa tipo costura de pelota — solo ornamento visual
interface Props {
	class?: string;
}
const { class: className } = Astro.props;
---

<div class:list={['flex items-center gap-3', className]} aria-hidden="true">
	<span class="h-px flex-1 bg-gradient-to-r from-transparent via-gold-400/45 to-transparent" />
	<svg
		class="h-4 w-10 shrink-0 text-gold-400/55"
		viewBox="0 0 40 16"
		fill="none"
		xmlns="http://www.w3.org/2000/svg"
		aria-hidden="true"
	>
		<path
			d="M4 8c4-4 8-4 12 0s8 4 12 0 8-4 12 0"
			stroke="currentColor"
			stroke-width="1.25"
			stroke-linecap="round"
			vector-effect="non-scaling-stroke"
		/>
		<path
			d="M4 8c4 4 8 4 12 0s8-4 12 0 8 4 12 0"
			stroke="currentColor"
			stroke-width="1.25"
			stroke-linecap="round"
			vector-effect="non-scaling-stroke"
		/>
	</svg>
	<span class="h-px flex-1 bg-gradient-to-r from-transparent via-gold-400/45 to-transparent" />
</div>
