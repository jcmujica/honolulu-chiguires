---
// Mini marcador estilo tablero — números con humor, no stats reales
interface Props {
	class?: string;
}
const { class: className } = Astro.props;
---

<div
	class:list={[
		'rounded-xl border border-navy-600/55 bg-navy-950/85 px-4 py-3 shadow-[inset_0_1px_0_0_oklch(0.9_0.02_95/0.06)] ring-1 ring-gold-400/10',
		className,
	]}
>
	<p class="mb-3 text-center text-[0.58rem] font-bold uppercase tracking-[0.28em] text-gold-400/95">
		Marcador · simulación
	</p>
	<div class="grid grid-cols-[minmax(0,1fr)_auto] gap-x-4 gap-y-1.5 text-[0.8rem] font-semibold tabular-nums">
		<span class="truncate text-reef-300/95">Chigüires</span>
		<span class="text-right text-sand-50">000 000 000</span>
		<span class="text-reef-400/80">Visitante misterioso</span>
		<span class="text-right text-sand-100/90">000 000 000</span>
	</div>
	<div
		class="mt-3 grid grid-cols-3 gap-2 border-t border-navy-700/50 pt-3 text-center text-[0.65rem] font-bold tabular-nums"
	>
		<div>
			<p class="text-[0.55rem] font-bold uppercase tracking-wider text-navy-400">R</p>
			<p class="font-display text-lg text-lava-300">0</p>
		</div>
		<div>
			<p class="text-[0.55rem] font-bold uppercase tracking-wider text-navy-400">H</p>
			<p class="font-display text-lg text-sand-50">0</p>
		</div>
		<div>
			<p class="text-[0.55rem] font-bold uppercase tracking-wider text-navy-400">E</p>
			<p class="font-display text-lg text-gold-400">0</p>
		</div>
	</div>
	<p class="mt-2 text-center text-[0.62rem] font-medium leading-snug text-navy-400">
		Entrada: baja del 1.º · Robos de base: pendientes de permiso del entrenador
	</p>
</div>
