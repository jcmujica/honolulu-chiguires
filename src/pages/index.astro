---
import Layout from '../layouts/Layout.astro';
import TeamLogo from '../components/TeamLogo.astro';
import BaseballDiamondBg from '../components/BaseballDiamondBg.astro';
import '../styles/global.css';
---

<Layout>
	<div
		class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(ellipse_90%_70%_at_15%_0%,oklch(0.42_0.11_193/0.24),transparent_55%),radial-gradient(ellipse_75%_55%_at_78%_8%,oklch(0.52_0.14_258/0.14),transparent_52%),radial-gradient(ellipse_65%_50%_at_92%_35%,oklch(0.58_0.18_48/0.14),transparent_48%),radial-gradient(ellipse_50%_45%_at_5%_85%,oklch(0.5_0.16_24/0.1),transparent_50%)]"
		aria-hidden="true"
	/>
	<div
		class="pointer-events-none fixed inset-0 -z-10 opacity-[0.055] [background-image:repeating-linear-gradient(108deg,oklch(0.42_0.06_250)_0,oklch(0.42_0.06_250)_1px,transparent_1px,transparent_14px)]"
		aria-hidden="true"
	/>

	<header
		class="sticky top-0 z-50 border-b border-dashed border-navy-600/40 bg-navy-950/90 pt-[env(safe-area-inset-top)] shadow-[0_1px_0_0_oklch(0.52_0.14_258/0.12)] backdrop-blur-md supports-[backdrop-filter]:bg-navy-950/75"
	>
		<div
			class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-x-3 gap-y-3 px-4 py-3.5 sm:gap-x-4 sm:px-8"
		>
			<a href="/" class="group flex min-w-0 flex-1 items-center gap-2.5 rounded-lg outline-none focus-visible:ring-2 focus-visible:ring-gold-400/80 focus-visible:ring-offset-2 focus-visible:ring-offset-navy-950 sm:flex-initial sm:gap-3.5 touch-manipulation">
				<span
					class="relative flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-full bg-navy-800 shadow-soft ring-2 ring-gold-400/30 transition duration-300 group-hover:ring-gold-400/55 sm:h-[3.25rem] sm:w-[3.25rem]"
				>
					<TeamLogo class="h-12 w-12 scale-[1.08] sm:h-[3.25rem] sm:w-[3.25rem]" />
				</span>
				<span class="min-w-0 text-left leading-[1.15]">
					<span class="block font-display text-[1.02rem] font-semibold tracking-tight text-sand-50 sm:text-lg sm:text-[1.35rem]"
						>Honolulu Chigüires</span
					>
					<span class="text-[0.75rem] font-semibold uppercase tracking-[0.2em] text-reef-300/95 sm:text-xs sm:tracking-[0.22em]"
						>Club de béisbol · liga del pantano</span
					>
				</span>
			</a>
			<nav
				class="order-last flex w-full basis-full items-center justify-center gap-0.5 rounded-full border border-navy-600/40 bg-navy-900/50 p-1 sm:order-none sm:w-auto sm:basis-auto sm:gap-1 sm:justify-self-center md:flex-1 md:justify-center"
				aria-label="Secciones principales"
			>
				<a
					class="inline-flex min-h-11 min-w-[2.75rem] flex-1 items-center justify-center rounded-full px-3 py-2 text-xs font-semibold text-sand-200 transition-colors duration-200 active:bg-navy-800/90 hover:bg-navy-800/80 hover:text-gold-300 sm:flex-initial sm:px-4 sm:py-2 sm:text-sm touch-manipulation"
					href="#historia">Banquillo</a
				>
				<a
					class="inline-flex min-h-11 min-w-[2.75rem] flex-1 items-center justify-center rounded-full px-3 py-2 text-xs font-semibold text-sand-200 transition-colors duration-200 active:bg-navy-800/90 hover:bg-navy-800/80 hover:text-vin-blue-300 sm:flex-initial sm:px-4 sm:py-2 sm:text-sm touch-manipulation"
					href="#calendario">Calendario</a
				>
				<a
					class="inline-flex min-h-11 min-w-[2.75rem] flex-1 items-center justify-center rounded-full px-3 py-2 text-xs font-semibold text-sand-200 transition-colors duration-200 active:bg-navy-800/90 hover:bg-navy-800/80 hover:text-vin-red-300 sm:flex-initial sm:px-4 sm:py-2 sm:text-sm touch-manipulation"
					href="#boletin">7.º inning</a
				>
			</nav>
			<a
				href="#boletin"
				class="shrink-0 rounded-full bg-lava-500 px-4 py-2.5 text-center text-xs font-semibold leading-snug text-navy-950 shadow-soft outline-none ring-1 ring-lava-400/35 transition duration-300 hover:bg-lava-400 hover:brightness-[1.03] active:scale-[0.98] focus-visible:ring-2 focus-visible:ring-gold-400 focus-visible:ring-offset-2 focus-visible:ring-offset-navy-950 sm:px-5 sm:text-sm touch-manipulation max-[380px]:max-w-[11.5rem]"
			>
				Al bat: tu correo
			</a>
		</div>
		<div class="vin-stripe" aria-hidden="true"></div>
	</header>

	<main id="contenido" class="grain relative bg-navy-950 text-sand-100">
		<section
			class="relative overflow-hidden px-4 pb-[clamp(3.25rem,11vw,7rem)] pt-[clamp(2.5rem,7vw,5rem)] sm:px-8 sm:pb-[clamp(4rem,12vw,7rem)] sm:pt-[clamp(3rem,8vw,5rem)]"
		>
			<BaseballDiamondBg
				class="absolute -right-[10%] top-[8%] h-[min(90vw,520px)] w-[min(90vw,520px)] opacity-90 sm:right-0 sm:top-[5%]"
			/>
			<div
				class="pointer-events-none absolute -right-32 top-0 h-[28rem] w-[28rem] rounded-full bg-lava-500/18 blur-[100px] sm:right-0"
				aria-hidden="true"
			/>
			<div
				class="pointer-events-none absolute -left-24 bottom-0 h-[26rem] w-[26rem] rounded-full bg-reef-600/16 blur-[100px]"
				aria-hidden="true"
			/>
			<div
				class="pointer-events-none absolute left-1/3 top-1/2 h-[18rem] w-[18rem] -translate-x-1/2 rounded-full bg-vin-blue-500/10 blur-[90px]"
				aria-hidden="true"
			/>

			<div
				class="relative mx-auto grid max-w-6xl gap-10 sm:gap-12 lg:grid-cols-[minmax(0,1.08fr)_minmax(260px,0.92fr)] lg:gap-14 lg:items-start lg:gap-x-[clamp(2rem,5vw,4rem)]"
			>
				<div class="hero-text-col reveal order-2 max-w-[40rem] pt-1 sm:pt-2 lg:order-1 lg:pt-6">
					<p
						class="mb-5 inline-flex max-w-full items-center gap-2 rounded-full border border-gold-400/30 bg-gradient-to-r from-navy-900/70 via-navy-900/55 to-navy-900/70 px-3.5 py-2 text-[0.75rem] font-semibold uppercase tracking-[0.18em] text-gold-400 shadow-[inset_0_1px_0_0_oklch(0.9_0.15_95/0.12)] sm:mb-6 sm:gap-2.5 sm:px-4 sm:text-xs sm:tracking-[0.2em]"
					>
						<span class="relative flex h-2 w-2">
							<span class="absolute inline-flex h-full w-full motion-safe:animate-ping rounded-full bg-lava-400 opacity-40"></span>
							<span class="relative inline-flex h-2 w-2 rounded-full bg-lava-400"></span>
						</span>
						Juego en curso (en nuestra cabeza)
					</p>

					<h1
						class="font-display text-[clamp(1.85rem,calc(4vw+0.8rem),3.85rem)] font-semibold leading-[1.08] tracking-tight text-sand-50 text-balance sm:text-[clamp(2.35rem,4.8vw,3.85rem)] sm:leading-[1.05]"
					>
						<span class="font-medium text-sand-100/95">Tranquilos como un capibara.</span>
						<span class="mt-3 block text-lava-300">Con hambre de campeones.</span>
						<span class="mt-4 block font-sans text-[1.05rem] font-semibold italic leading-snug text-gold-400/95 sm:text-lg">
							(Sprint de la ardilla: en revisión de video.)
						</span>
					</h1>
					<p
						class="mt-6 max-w-xl text-base font-medium leading-relaxed text-reef-200 sm:mt-8 sm:text-[1.05rem] sm:leading-[1.65] sm:text-lg"
					>
						Los Honolulu Chigüires mezclan brisa de outfield y sal marina con discusión de señales en el
						dugout. Fuimos campeones en 2022. Robo de base: solo si el entrenador deja. Toque de bola:
						negociable. Mascota: siempre en el roster.
					</p>
					<div class="mt-9 flex w-full flex-col gap-3 sm:mt-11 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4">
						<a
							href="#calendario"
							class="inline-flex min-h-12 w-full items-center justify-center rounded-full bg-lava-500 px-6 py-3.5 text-[0.95rem] font-semibold text-navy-950 shadow-glow outline-none ring-1 ring-lava-400/30 transition duration-300 hover:bg-lava-400 active:scale-[0.99] focus-visible:ring-2 focus-visible:ring-gold-400 focus-visible:ring-offset-2 focus-visible:ring-offset-navy-950 sm:w-auto sm:px-8 touch-manipulation"
						>
							Ver calendario (spoiler: TBA)
						</a>
						<a
							href="#historia"
							class="inline-flex min-h-12 w-full items-center justify-center rounded-full border border-reef-500/35 bg-navy-900/35 px-6 py-3.5 text-[0.95rem] font-semibold text-sand-100 outline-none transition duration-300 hover:border-lava-400/45 hover:bg-navy-800/55 active:scale-[0.99] focus-visible:ring-2 focus-visible:ring-reef-400/80 focus-visible:ring-offset-2 focus-visible:ring-offset-navy-950 sm:w-auto sm:px-8 touch-manipulation"
						>
							Leer el reglamento informal
						</a>
					</div>

					<div
						class="mt-12 grid grid-cols-1 gap-8 border-t border-dashed border-chalk-400/25 pt-10 sm:mt-16 sm:flex sm:flex-wrap sm:items-end sm:gap-x-10 sm:gap-y-6 sm:pt-12"
					>
						<div>
							<p class="text-[0.65rem] font-bold uppercase tracking-[0.2em] text-vin-blue-400/95">Home</p>
							<p class="mt-1.5 font-display text-xl font-semibold tracking-tight text-sand-50">808 · Oʻahu</p>
						</div>
						<span class="hidden text-gold-500/45 sm:inline" aria-hidden="true">|</span>
						<div>
							<p class="text-[0.65rem] font-bold uppercase tracking-[0.2em] text-gold-400/90">Récord</p>
							<p class="mt-1.5 font-display text-xl font-semibold tracking-tight text-sand-50">∞ buena vibra</p>
						</div>
						<span class="hidden text-gold-500/45 sm:inline" aria-hidden="true">|</span>
						<div>
							<p class="text-[0.65rem] font-bold uppercase tracking-[0.2em] text-vin-red-400/95">Hot dogs</p>
							<p class="mt-1.5 font-display text-xl font-semibold tracking-tight text-sand-50">Sí, por favor</p>
						</div>
					</div>
				</div>

				<div
					class="hero-logo-card reveal relative order-1 w-full min-w-0 justify-self-stretch lg:order-2 lg:mt-4 lg:justify-self-end"
				>
					<div
						class="relative overflow-hidden rounded-[2rem] bg-gradient-to-br from-gold-400/[0.14] via-vin-blue-500/[0.08] to-navy-950 p-[1px] shadow-soft ring-1 ring-navy-600/35"
					>
						<div
							class="relative overflow-hidden rounded-[calc(2rem-1px)] bg-gradient-to-br from-navy-800/98 to-navy-950 px-5 pb-8 pt-7 sm:px-8 sm:pb-10 sm:pt-9"
						>
							<p
								class="mb-4 text-center font-display text-[0.65rem] font-bold uppercase tracking-[0.35em] text-gold-400/80"
							>
								Programa del día
							</p>
							<div
								class="pointer-events-none absolute -right-10 top-1/2 h-48 w-48 -translate-y-1/2 rounded-full bg-lava-500/12 blur-3xl"
								aria-hidden="true"
							/>
							<div class="relative flex flex-col items-stretch sm:items-center sm:text-center">
								<div
									class="relative mx-auto mb-6 w-full max-w-[300px] drop-shadow-[0_24px_48px_oklch(0.15_0.08_258/0.55)] sm:max-w-[320px]"
								>
									<TeamLogo class="max-h-[min(52vw,320px)]" priority={true} />
								</div>
								<p class="font-display text-[1.65rem] font-semibold tracking-tight text-sand-50">
									Chigüires de Honolulu
								</p>
								<p class="mx-auto mt-3 max-w-sm text-sm font-medium leading-relaxed text-reef-200/95">
									Capibara en el plato, Diamond Head al fondo, hibiscos en foul. Si ves una pelota
									perdida, no es nuestra (probablemente sí).
								</p>
								<div
									class="mt-9 flex w-full flex-col gap-3.5 rounded-2xl border border-navy-600/35 bg-navy-950/55 p-5 text-left backdrop-blur-[2px]"
								>
									<div class="flex flex-col gap-1.5 text-sm sm:flex-row sm:items-center sm:justify-between sm:gap-4">
										<span class="font-medium text-reef-300">Próxima serie en casa</span>
										<span class="font-display font-semibold text-gold-400 sm:max-w-[12rem] sm:text-right">
											Calendario en modo “TBA”
										</span>
									</div>
									<div class="h-px bg-gradient-to-r from-transparent via-navy-600/80 to-transparent" />
									<div class="flex items-center justify-between gap-4 text-sm">
										<span class="font-medium text-reef-300">Zona de aficionados</span>
										<span class="shrink-0 font-semibold tracking-wide text-sand-100">The Marsh</span>
									</div>
								</div>
							</div>
						</div>
					</div>
					<p class="mt-5 max-w-sm text-[0.8rem] font-medium leading-snug text-navy-400 sm:mx-auto sm:text-center lg:mx-0 lg:text-left">
						Energía de ligas menores, aloha de Grandes Ligas. MLB: aún no nos llama; nosotros tampoco
						tenemos su número.
					</p>
				</div>
			</div>
		</section>

		<div class="mx-auto max-w-6xl px-4 pb-10 sm:px-8">
			<p
				class="rounded-xl border border-dashed border-lava-500/35 bg-gradient-to-br from-navy-900/65 via-navy-900/45 to-navy-950/80 px-4 py-3.5 text-center text-[0.85rem] font-medium leading-snug text-reef-200/95 shadow-[inset_0_1px_0_0_oklch(0.58_0.12_256/0.15)] sm:text-sm"
			>
				<strong class="text-gold-400/95">Norma local:</strong> si tropiezas corriendo bases, cuenta como slide
				artístico. El árbitro eres tú.
			</p>
		</div>

		<section
			id="historia"
			class="border-t border-dashed border-navy-700/50 bg-gradient-to-b from-navy-900/70 via-[oklch(0.22_0.06_258/0.92)] to-navy-950 px-4 py-[clamp(3.25rem,9vw,6.5rem)] sm:px-8 sm:py-[clamp(4rem,10vw,6.5rem)]"
		>
			<div class="mx-auto max-w-6xl">
				<div class="grid gap-10 sm:gap-12 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:gap-20">
					<div class="reveal max-w-xl">
						<p class="mb-3 font-display text-sm font-medium italic text-gold-400/90">Desde el banquillo</p>
						<h2 class="font-display text-[clamp(1.65rem,calc(3vw+0.85rem),2.75rem)] font-semibold leading-tight tracking-tight text-sand-50 text-balance sm:text-[clamp(1.85rem,3.5vw,2.75rem)]">
							Raíces hawaianas, <span class="text-lava-300">reglas de béisbol (casi)</span>
						</h2>
						<p class="mt-6 text-base font-medium leading-relaxed text-reef-200/95 sm:mt-8 sm:text-lg">
							Viento en la camiseta, café en el termo, gritos en el bullpen que nadie entiende del todo.
							Cada entrada es un mini festival: alguien trae sunscreen, otro trae playlist, la mascota
							firma autógrafos con la paciencia de un rocoso.
						</p>
					</div>
					<ul class="reveal reveal-delay-2 space-y-0 divide-y divide-navy-700/45 border-t border-b border-navy-700/35">
						<li class="flex gap-4 py-6 first:pt-0 last:pb-0 sm:gap-5 sm:py-7">
							<span class="font-display text-2xl font-semibold tabular-nums text-gold-400/95">01</span>
							<div>
								<p class="font-semibold text-sand-50">Viernes de lei</p>
								<p class="mt-2 text-sm font-medium leading-relaxed text-reef-300/95">
									Colores del logo o te multamos en broma. Plumeria: bonus de carisma +2.
								</p>
							</div>
						</li>
						<li class="flex gap-4 py-6 sm:gap-5 sm:py-7">
							<span class="font-display text-2xl font-semibold tabular-nums text-vin-blue-400/95">02</span>
							<div>
								<p class="font-semibold text-sand-50">Shaka &amp; fair play</p>
								<p class="mt-2 text-sm font-medium leading-relaxed text-reef-300/95">
									Animamos fuerte, festejamos limpio y recogemos lo que traemos (incluido el ego).
								</p>
							</div>
						</li>
						<li class="flex gap-4 py-6 sm:gap-5 sm:py-7">
							<span class="font-display text-2xl font-semibold tabular-nums text-vin-red-400/95">03</span>
							<div>
								<p class="font-semibold text-sand-50">Código capibara</p>
								<p class="mt-2 text-sm font-medium leading-relaxed text-reef-300/95">
									Hidratar, compartir snacks y no apurar el bate: el tiempo aquí va a ritmo de marea.
								</p>
							</div>
						</li>
					</ul>
				</div>
			</div>
		</section>

		<section
			id="calendario"
			class="bg-[radial-gradient(ellipse_80%_60%_at_50%_0%,oklch(0.52_0.11_258/0.12),transparent_65%)] px-4 py-[clamp(3.25rem,9vw,6.5rem)] sm:px-8 sm:py-[clamp(4rem,10vw,6.5rem)]"
		>
			<div class="mx-auto max-w-6xl">
				<div
					class="reveal flex flex-col gap-6 border-b border-dashed border-navy-700/35 pb-10 sm:flex-row sm:items-end sm:justify-between"
				>
					<div class="max-w-xl">
						<p class="font-display text-sm font-medium italic text-gold-400/85">Pizarra de futuro</p>
						<h2 class="mt-1 font-display text-[clamp(1.65rem,calc(3vw+0.85rem),2.65rem)] font-semibold tracking-tight text-sand-50 text-balance sm:text-[clamp(1.85rem,3.5vw,2.65rem)]">
							Próximas fechas
						</h2>
						<p class="mt-3 text-base font-medium leading-relaxed text-reef-300/95 sm:mt-4">
							El calendario todavía está calentando en el bullpen. Apúntate y te avisamos antes que el
							rival (que es el calendario).
						</p>
					</div>
					<span
						class="inline-flex w-fit items-center rounded-lg border border-gold-400/35 bg-gradient-to-r from-navy-900/70 to-navy-900/45 px-3.5 py-2 text-[0.65rem] font-bold uppercase tracking-[0.2em] text-gold-400 shadow-[inset_0_1px_0_0_oklch(0.9_0.12_95/0.15)]"
					>
						Temporada 2026
					</span>
				</div>

				<div class="mt-12 grid gap-5 lg:grid-cols-12 lg:gap-6">
					<article
						class="reveal reveal-delay-1 group flex min-h-[168px] flex-col justify-between rounded-2xl border border-navy-700/40 border-t-4 border-t-lava-500 bg-navy-900/35 p-5 shadow-soft transition duration-300 hover:-translate-y-0.5 hover:border-navy-600/50 hover:border-t-lava-400 hover:bg-navy-900/50 hover:shadow-[0_20px_40px_-18px_oklch(0.55_0.17_48/0.35)] sm:min-h-[200px] sm:p-7 lg:col-span-7"
					>
						<div>
							<p class="font-plate font-display text-4xl font-bold text-lava-400">TBA</p>
							<h3 class="mt-4 font-display text-xl font-semibold text-sand-50">Inauguración en casa</h3>
							<p class="mt-3 text-sm font-medium text-reef-400/95">El día que sepamos el día, lo sabrás.</p>
						</div>
						<p class="mt-6 text-[0.7rem] font-semibold uppercase tracking-widest text-navy-400">Serie A · hype</p>
					</article>
					<article
						class="reveal reveal-delay-2 group flex min-h-[168px] flex-col justify-between rounded-2xl border border-navy-700/40 border-t-4 border-t-gold-400 bg-navy-900/35 p-5 shadow-soft transition duration-300 hover:-translate-y-0.5 hover:border-navy-600/50 hover:border-t-gold-300 hover:bg-navy-900/50 hover:shadow-[0_20px_40px_-18px_oklch(0.82_0.12_92/0.2)] sm:min-h-[200px] sm:p-7 lg:col-span-5"
					>
						<div>
							<p class="font-plate font-display text-4xl font-bold text-lava-400">TBA</p>
							<h3 class="mt-4 font-display text-xl font-semibold text-sand-50">Doble cartelera al atardecer</h3>
							<p class="mt-3 text-sm font-medium text-reef-400/95">Naranja opcional, actitud obligatoria.</p>
						</div>
						<p class="mt-6 text-[0.7rem] font-semibold uppercase tracking-widest text-navy-400">Noche larga</p>
					</article>
					<article
						class="reveal reveal-delay-3 flex flex-col justify-between rounded-2xl border border-navy-700/40 border-t-4 border-t-reef-500 bg-gradient-to-r from-navy-900/55 via-navy-900/40 to-navy-950/85 p-5 shadow-soft transition duration-300 hover:-translate-y-0.5 hover:border-navy-600/50 hover:border-t-reef-400 hover:shadow-[0_20px_44px_-18px_oklch(0.46_0.1_193/0.35)] sm:p-7 lg:col-span-12 lg:flex-row lg:items-center lg:gap-10"
					>
						<div>
							<p class="font-plate font-display text-4xl font-bold text-lava-400">TBA</p>
							<h3 class="mt-2 font-display text-xl font-semibold text-sand-50 lg:mt-1">Niños corren las bases</h3>
							<p class="mt-2 text-sm font-medium text-reef-400/95 lg:mt-1">Padres: filmen horizontal, por favor al universo.</p>
						</div>
						<p class="mt-6 shrink-0 text-[0.7rem] font-semibold uppercase tracking-widest text-navy-400 lg:mt-0">
							Domingo · familia
						</p>
					</article>
				</div>
			</div>
		</section>

		<section
			id="boletin"
			class="relative mx-4 mb-[clamp(2.5rem,7vw,5rem)] overflow-hidden rounded-[1.5rem] border border-lava-500/30 bg-gradient-to-br from-navy-800/95 via-navy-900/98 to-navy-950 px-5 py-[clamp(2.5rem,7vw,4.5rem)] shadow-soft ring-1 ring-gold-400/15 ring-inset before:pointer-events-none before:absolute before:inset-0 before:rounded-[inherit] before:bg-[radial-gradient(ellipse_90%_80%_at_100%_0%,oklch(0.58_0.12_256/0.12),transparent_55%)] before:content-[''] sm:mx-8 sm:rounded-[2rem] sm:px-12"
		>
			<div class="reveal mx-auto max-w-2xl">
				<div class="text-center sm:text-left">
					<p class="font-display text-sm font-medium italic text-gold-400/85">7.º inning stretch (digital)</p>
					<h2 class="mt-2 font-display text-[clamp(1.65rem,calc(2.8vw+0.85rem),2.5rem)] font-semibold tracking-tight text-sand-50 text-balance sm:text-[clamp(1.85rem,3.2vw,2.5rem)]">
						Únete al pantano
					</h2>
					<p class="mt-5 text-base font-medium leading-relaxed text-reef-200/95">
						Recibe fechas, rumores de merch y datos capibara inútiles pero entrañables. Sin spam: solo
						aloha y, a veces, un “¿ya es viernes?”.
					</p>
				</div>
				<form
					class="mt-10 flex max-w-xl flex-col gap-3 sm:mx-auto sm:flex-row sm:items-stretch lg:mx-0"
					action="#"
					method="post"
				>
					<label class="sr-only" for="email">Correo electrónico</label>
					<input
						id="email"
						name="email"
						type="email"
						autocomplete="email"
						placeholder="tu@correo.com"
						class="min-h-12 flex-1 rounded-xl border border-navy-600/55 bg-navy-950/45 px-4 text-base text-sand-50 placeholder:text-navy-400/90 outline-none ring-0 transition duration-300 focus:border-lava-400/80 focus:ring-2 focus:ring-lava-500/35"
					/>
					<button
						type="submit"
						class="min-h-12 w-full shrink-0 rounded-xl bg-lava-500 px-6 text-sm font-semibold text-navy-950 outline-none transition duration-300 hover:bg-lava-400 active:scale-[0.99] focus-visible:ring-2 focus-visible:ring-gold-400 focus-visible:ring-offset-2 focus-visible:ring-offset-navy-900 sm:w-auto sm:px-8 touch-manipulation"
					>
						Mandar al bullpen (tu inbox)
					</button>
				</form>
				<p class="mt-5 text-center text-[0.8rem] font-medium text-navy-400/95 sm:text-left">
					Demo: cuando conectes tu boletín real, borramos esta letra chiquita y fingimos seriedad.
				</p>
			</div>
		</section>
	</main>

	<footer
