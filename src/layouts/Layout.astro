---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Honolulu Chigüires — Club de béisbol',
	description = 'Honolulu Chigüires: béisbol isleño con aloha, humor de dugout y cero pelotas perdidas (oficialmente).',
} = Astro.props;

const ogImage = '/chiguires.png';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/chiguires.png" />
		<link rel="apple-touch-icon" href="/chiguires.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:locale" content="es" />
		<meta property="og:image" content={ogImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content={ogImage} />
		<meta name="theme-color" content="#0B2447" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700&family=Lexend:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-dvh overflow-x-hidden">
		<slot />
	</body>
</html>
